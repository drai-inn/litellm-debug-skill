# litellm-debug — environment template
#
# Copy this file to .env and fill in the credentials for the tier(s) you
# want to test. Each rung of the onboarding ladder needs exactly one
# more variable than the rung below.
#
# .env is gitignored. Never commit credentials.

# ---- Public tier (required) ----
# The base URL of the LiteLLM proxy you want to debug.
# Example: https://my-proxy.example.com   or   http://localhost:4000
LITELLM_BASE_URL=

# ---- User tier ----
# Any virtual key issued by the proxy (does not need to be admin).
# LITELLM_USER_KEY=

# ---- Admin tier ----
# The proxy master key.
# LITELLM_MASTER_KEY=

# ---- Telemetry tier (Langfuse first; other backends added on demand) ----
# LANGFUSE_HOST=
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=

# ---- Database tier (gated; opt-in flag required in addition to DSN) ----
# Direct Postgres access bypasses the proxy's auth, scoping, and audit log.
# Use only when no boundary-respecting tier can answer the question.
# LITELLM_DB_DSN=
# LITELLM_DB_OPTIN=

# ---- Spec pinning (optional; both default to latest stable) ----
# LITELLM_VERSION_PRIMARY=
# LITELLM_VERSION_COMPARISON=
